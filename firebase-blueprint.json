{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "storageUsed": { "type": "integer", "description": "Bytes used in cloud storage" },
        "storageLimit": { "type": "integer", "description": "Bytes limit (e.g., 10GB)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A Studio One project (Song, Video, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Song", "Podcast", "YouTube Video", "Reels", "Album Art"] },
        "bpm": { "type": "integer" },
        "key": { "type": "string" },
        "data": { "type": "object", "description": "Serialized timeline state (tracks, clips)" },
        "isPublic": { "type": "boolean" },
        "collaborators": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "title", "type"]
    },
    "Asset": {
      "title": "Asset",
      "description": "A media asset uploaded by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "mimeType": { "type": "string" },
        "size": { "type": "integer" },
        "storagePath": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "storagePath"]
    },
    "Version": {
      "title": "Project Version",
      "description": "Historical snapshot of a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "snapshot": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "snapshot"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Main project storage"
    },
    "/projects/{projectId}/versions/{versionId}": {
      "schema": "Version",
      "description": "Project version history"
    },
    "/users/{userId}/assets/{assetId}": {
      "schema": "Asset",
      "description": "User's personal asset library"
    }
  }
}
